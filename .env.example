# MemWal (delegate key only — ADR-002)
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=http://localhost:3001
# Optional Walrus namespace (defaults to "default" when unset — see loadMemWalConfigFromEnv)
MEMWAL_NAMESPACE=
# When true/1/yes, remember() uses rememberAndWait (blocks until blob id is known)
MEMWAL_WAIT_FOR_REMEMBER=
MEMWAL_PACKAGE_ID=

# MemWal++ Move package (after publish)
MARKETPLACE_PACKAGE_ID=
NEXT_PUBLIC_MARKETPLACE_PACKAGE_ID=

# Sui
SUI_NETWORK=mainnet
NEXT_PUBLIC_SUI_NETWORK=mainnet

# Seal (example from masterplan — verify current)
SEAL_PACKAGE_ID=0xcb83a248bda5f7a0a431e6bf9e96d184e604130ec5218696e3f1211113b447b7
