# =============================================================================
# MemWal++ environment template (copy to .env — never commit secrets)
# See SUBMISSION.md and README.md for judge quick start
# =============================================================================

# --- MemWal / Walrus (delegate key only — ADR-002) ---
# Required for live durable promotion (pnpm agent:demo with blob ids)
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=http://localhost:3001
# Walrus namespace for remember/recall (default: "default")
MEMWAL_NAMESPACE=bounty-demo
# 1 | true | yes — block until Walrus blob id is known after remember
MEMWAL_WAIT_FOR_REMEMBER=
# Phase 2 durable client tuning
MEMWAL_RETRY_MAX=3
MEMWAL_MIN_REQUEST_INTERVAL_MS=0
# Minimum scoreQuality (0–100) for pushOne / syncPending
MEMWAL_SYNC_QUALITY_MIN=40
# Agent demos: auto pushOne after afterThink (0 | 1)
MEMWAL_AUTO_PUSH=0

# --- MemWal++ Move package (mainnet) ---
MARKETPLACE_PACKAGE_ID=0x48db008a3c9e638dd17d20702632d9909c3c075e44eb339f890fb29503ec3050
NEXT_PUBLIC_MARKETPLACE_PACKAGE_ID=0x48db008a3c9e638dd17d20702632d9909c3c075e44eb339f890fb29503ec3050
MEMWAL_PACKAGE_ID=

# --- Sui network ---
SUI_NETWORK=mainnet
NEXT_PUBLIC_SUI_NETWORK=mainnet

# --- Seal (verify against current Mysten docs before production) ---
SEAL_PACKAGE_ID=0xcb83a248bda5f7a0a431e6bf9e96d184e604130ec5218696e3f1211113b447b7

# --- Dashboard (apps/dashboard) ---
# NEXT_PUBLIC_MARKETPLACE_PACKAGE_ID is set above
