{
  "name": "@memwalpp/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server — universal front door to MemWal Agent Memory hybrid layer",
  "bin": {
    "memwal-mcp": "./dist/cli.js"
  },
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@memwalpp/core": "workspace:*",
    "@memwalpp/local-memory": "workspace:*",
    "@memwalpp/memwal-client": "workspace:*",
    "@memwalpp/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
