{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "NEXT_PUBLIC_MARKETPLACE_PACKAGE_ID",
    "NEXT_PUBLIC_SUI_NETWORK",
    "SUI_NETWORK"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "@memwalpp/shared#build": {
      "outputs": []
    },
    "@memwalpp/ui#build": {
      "outputs": []
    },
    "@memwalpp/local-memory#build": {
      "outputs": []
    },
    "@memwalpp/memwal-client#build": {
      "outputs": []
    },
    "@memwalpp/core#build": {
      "outputs": []
    },
    "memwalpp-cli#build": {
      "outputs": ["dist/**"]
    },
    "@memwalpp/dashboard#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["NEXT_PUBLIC_SUI_NETWORK", "NEXT_PUBLIC_MARKETPLACE_PACKAGE_ID"]
    },
    "check": {
      "dependsOn": ["^check"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
