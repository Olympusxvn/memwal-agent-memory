{
  "name": "memwalpp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "pnpm test:packages",
    "test:turbo": "turbo run test",
    "test:packages": "pnpm --filter @memwalpp/local-memory exec vitest run && pnpm --filter @memwalpp/core exec vitest run && pnpm --filter @memwalpp/memwal-client exec vitest run && pnpm --filter @memwalpp/mcp exec vitest run",
    "mcp:build": "pnpm --filter @memwalpp/mcp build",
    "mcp:start": "pnpm mcp:build && pnpm --filter @memwalpp/mcp start",
    "mcp:dev": "pnpm --filter @memwalpp/mcp dev",
    "mcp:e2e": "pnpm mcp:build && pnpm --filter @memwalpp/mcp exec vitest run test/e2e-stdio.test.ts",
    "test:local": "pnpm --filter @memwalpp/local-memory exec vitest",
    "lint": "turbo run lint",
    "demo": "tsx scripts/demo-runner.ts",
    "agent:demo": "pnpm --filter agent-swarm run demo",
    "agent:bounty-hunt": "pnpm --filter agent-swarm run bounty-hunt",
    "contracts:build": "cd packages/sui-contracts && sui move build",
    "contracts:test": "cd packages/sui-contracts && sui move test",
    "contracts:info": "tsx scripts/move-package-info.ts",
    "contracts:upgrade-v2": "bash scripts/upgrade-contracts-v2.sh",
    "contracts:bootstrap-v2": "tsx scripts/bootstrap-v2.ts"
  },
  "devDependencies": {
    "@memwalpp/shared": "workspace:*",
    "@mysten/sui": "^2.16.2",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.18.2",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "engines": {
    "node": ">=20"
  }
}
