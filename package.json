{
  "name": "memwalpp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "pnpm test:packages",
    "test:turbo": "turbo run test",
    "test:packages": "pnpm --filter @memwalpp/local-memory exec vitest run && pnpm --filter @memwalpp/core exec vitest run && pnpm --filter @memwalpp/memwal-client exec vitest run && pnpm --filter @memwalpp/mcp exec vitest run",
    "mcp:build": "pnpm --filter @memwalpp/mcp build",
    "mcp:start": "pnpm mcp:build && pnpm --filter @memwalpp/mcp start",
    "mcp:dev": "pnpm --filter @memwalpp/mcp dev",
    "mcp:e2e": "pnpm mcp:build && pnpm --filter @memwalpp/mcp exec vitest run test/e2e-stdio.test.ts",
    "test:local": "pnpm --filter @memwalpp/local-memory exec vitest",
    "lint": "turbo run lint",
    "demo": "tsx scripts/demo-runner.ts",
    "agent:demo": "pnpm --filter agent-swarm run demo",
    "agent:bounty-hunt": "pnpm --filter agent-swarm run bounty-hunt",
    "agent:shared-memory": "pnpm --filter agent-swarm run shared-memory",
    "agent:resume-session": "pnpm --filter agent-swarm run resume-session",
    "bench:recall": "tsx scripts/bench-recall.ts",
    "mcp:e2e:portable": "pnpm mcp:build && pnpm --filter @memwalpp/mcp exec vitest run test/e2e-portable.test.ts",
    "memwal:restore-smoke": "tsx scripts/memwal-restore-smoke.ts",
    "contracts:build": "cd packages/sui-contracts && sui move build",
    "contracts:test": "cd packages/sui-contracts && sui move test",
    "contracts:info": "tsx scripts/move-package-info.ts",
    "contracts:upgrade-v2": "bash scripts/upgrade-contracts-v2.sh",
    "contracts:bootstrap-v2": "tsx scripts/bootstrap-v2.ts",
    "demo:voiceover": "python scripts/demo-video/generate-voiceover.py --locale en",
    "demo:voiceover:vi": "python scripts/demo-video/generate-voiceover.py --locale vi",
    "demo:voiceover:all": "python scripts/demo-video/generate-voiceover.py --locale en --locale vi",
    "demo:export": "node scripts/demo-video/export-demo.mjs",
    "demo:export:vi": "node scripts/demo-video/export-demo.mjs --locale vi",
    "demo:export:fast": "node scripts/demo-video/export-demo.mjs --skip-broll",
    "demo:publish": "pnpm demo:voiceover && pnpm demo:export",
    "doc-hub:sync": "node scripts/sync-doc-hub.mjs"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@memwalpp/shared": "workspace:*",
    "@mysten/sui": "^2.16.2",
    "@types/node": "^22.10.1",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.18.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
